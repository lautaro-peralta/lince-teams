# Variables de entorno de Lince Teams en la VM.
# Copiar a /etc/lince-teams/teams.env y completar. NO commitear el archivo real.
#   sudo mkdir -p /etc/lince-teams
#   sudo cp /opt/lince-teams/deploy/teams.env.example /etc/lince-teams/teams.env
#   sudo nano /etc/lince-teams/teams.env

# ── Base de datos ────────────────────────────────────────────────────────────
# Postgres de Supabase (Session pooler, IPv4). Debe ser el MISMO proyecto que
# Lince Automate para compartir public.profiles. Sin esta variable, usa SQLite.
DATABASE_URL=postgresql://postgres.xxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Modo unificado (login compartido con el panel /admin) ────────────────────
# Con estas dos presentes, Teams valida el JWT de Supabase y desactiva su
# registro/login propios. Son valores públicos.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...anon-key...
# A dónde mandar a iniciar sesión sin sesión (por defecto /admin, que sirve
# cuando Teams se sirve en /teams del mismo dominio vía el proxy).
LINCE_LOGIN_URL=/admin

# ── Whisper (transcripción) ──────────────────────────────────────────────────
# En Ampere A1 (mucha RAM) "small" va holgado; "medium" también entra.
LINCE_MODEL=small
LINCE_COMPUTE_TYPE=int8

# ── CORS ─────────────────────────────────────────────────────────────────────
# En el deploy proxeado same-origin NO hace falta (todo llega como el dominio
# del panel). Solo si pegás a este host cross-origin, listá el/los origen(es):
# LINCE_CORS_ORIGINS=https://lince-automate.com.ar
